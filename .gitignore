# --- Build Directories ---
# Most people use 'build', but some use 'out' or 'cmake-build-debug'
build/
out/
cmake-build-*/

# --- CMake Generated Files ---
# These are created whenever you run 'cmake ..'
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
Makefile
install_manifest.txt
compile_commands.json
_deps/

# --- Executables & Libraries ---
# Ignore the final compiled binaries
*.exe
*.out
*.app
*.so
*.a
*.lib
*.dll

# --- System & IDE Files ---
# Linux/KDE specific
.directory
*~

# IDE-specific (if you ever use them)
.vscode/
.idea/
*.user

# Language Server Metadata
.cache/
.clangd/
compile_commands.json
